{
	"version": "0.2.0",
	"configurations": [
		{
			// Debugger ATTACHED — use only when you want breakpoints. The V8
			// inspector taxes the async-heavy Mixpanel import ~30x (CPU pinned,
			// ~0.68 rps). For a normal fast run, use the "🚀 run dungeon" task
			// (Cmd+Shift+B) defined in .vscode/tasks.json instead.
			"type": "node",
			"request": "launch",
			"name": "🐞 debug dungeon",
			"program": "${workspaceFolder}/scripts/run-dungeon.mjs",
			"args": ["${file}"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"],
			"preLaunchTask": "npm: prune"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "📄 current file",
			"program": "${file}",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"env": { "NODE_ENV": "dev" },
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "🧪 test",
			"program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
			"args": ["run"],
			"env": { "NODE_ENV": "test" },
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "📦 dungeon → json",
			"program": "${workspaceFolder}/scripts/dungeon-to-json.mjs",
			"args": ["${file}"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "📥 json → dungeon",
			"program": "${workspaceFolder}/scripts/json-to-dungeon.mjs",
			"args": ["${file}"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "node",
			"request": "launch",
			"name": "🔍 typecheck",
			"program": "${workspaceFolder}/node_modules/typescript/bin/tsc",
			"args": ["--noEmit"],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**"]
		}
	]
}
