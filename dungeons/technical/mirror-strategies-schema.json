{
  "events": [
    {
      "event": "page view",
      "weight": 10,
      "properties": {
        "page": [
          "/account",
          "/",
          "/help",
          "/product",
          "/pricing"
        ]
      }
    },
    {
      "event": "checkout",
      "weight": 3,
      "properties": {
        "amount": {
          "$range": [
            44,
            154
          ]
        },
        "currency": [
          "USD",
          "EUR",
          "GBP"
        ]
      }
    },
    {
      "event": "profile update",
      "weight": 4,
      "properties": {
        "field": [
          "name",
          "email",
          "avatar",
          "address",
          "phone"
        ]
      }
    },
    {
      "event": "subscription change",
      "weight": 2,
      "properties": {
        "plan": [
          "free",
          "starter",
          "pro",
          "enterprise"
        ],
        "action": [
          "upgrade",
          "downgrade",
          "cancel",
          "renew"
        ]
      }
    },
    {
      "event": "login",
      "weight": 8,
      "properties": {
        "method": [
          "password",
          "google",
          "sso"
        ]
      }
    }
  ],
  "userProps": {
    "plan": [
      "free",
      "starter",
      "pro",
      "enterprise"
    ]
  }
}
