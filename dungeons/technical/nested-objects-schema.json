{
  "events": [
    {
      "event": "checkout",
      "weight": 3,
      "properties": {
        "cart": {
          "$type": "object[]",
          "$keys": [
            "product_id",
            "name",
            "price",
            "quantity",
            "category"
          ]
        },
        "total_amount": {
          "$range": [
            408,
            1563
          ]
        },
        "currency": [
          "USD",
          "EUR",
          "GBP",
          "JPY",
          "CAD"
        ],
        "session_id": {
          "$type": "string"
        },
        "metadata": {
          "$type": "object"
        }
      }
    },
    {
      "event": "search performed",
      "weight": 5,
      "properties": {
        "query": [
          "laptop",
          "shoes",
          "headphones",
          "jacket",
          "phone case",
          "coffee maker",
          "backpack",
          "monitor",
          "keyboard",
          "mouse"
        ],
        "results": {
          "$type": "object[]",
          "$keys": [
            "result_id",
            "title",
            "score",
            "sponsored"
          ]
        },
        "result_count": {
          "$range": [
            6,
            46
          ]
        },
        "top_result_id": {
          "$type": "string"
        },
        "session_id": {
          "$type": "string"
        },
        "metadata": {
          "$type": "object"
        }
      }
    },
    {
      "event": "form submitted",
      "weight": 4,
      "properties": {
        "form_name": [
          "checkout",
          "signup",
          "contact",
          "feedback",
          "settings",
          "profile"
        ],
        "fields": {
          "$type": "object[]",
          "$keys": [
            "field_name",
            "value",
            "valid"
          ]
        },
        "submission_valid": [
          true,
          false
        ],
        "session_id": {
          "$type": "string"
        },
        "metadata": {
          "$type": "object"
        }
      }
    },
    {
      "event": "page view",
      "weight": 8,
      "properties": {
        "page": [
          "/",
          "/products",
          "/cart",
          "/search",
          "/account",
          "/help",
          "/about"
        ],
        "product_id": {
          "$type": "string"
        },
        "session_id": {
          "$type": "string"
        },
        "metadata": {
          "$type": "object"
        }
      }
    }
  ],
  "userProps": {
    "plan": [
      "free",
      "basic",
      "pro",
      "enterprise"
    ]
  }
}
