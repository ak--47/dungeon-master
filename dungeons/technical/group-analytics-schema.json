{
  "events": [
    {
      "event": "feature used",
      "weight": 8,
      "properties": {
        "feature": [
          "dashboard",
          "reports",
          "settings",
          "api",
          "integrations"
        ]
      }
    },
    {
      "event": "subscription change",
      "weight": 2,
      "properties": {
        "plan": [
          "free",
          "starter",
          "business",
          "enterprise"
        ],
        "action": [
          "upgrade",
          "downgrade",
          "renew"
        ]
      }
    },
    {
      "event": "support ticket",
      "weight": 3,
      "properties": {
        "priority": [
          "low",
          "medium",
          "high"
        ],
        "category": [
          "billing",
          "technical",
          "onboarding",
          "feature request"
        ]
      }
    },
    {
      "event": "task completed",
      "weight": 7,
      "properties": {
        "type": [
          "bug",
          "feature",
          "chore",
          "docs"
        ],
        "points": {
          "$range": [
            1,
            12
          ]
        }
      }
    },
    {
      "event": "meeting scheduled",
      "weight": 4,
      "properties": {
        "duration": [
          15,
          30,
          45,
          60
        ],
        "type": [
          "standup",
          "planning",
          "retro",
          "1:1",
          "all-hands"
        ]
      }
    },
    {
      "event": "code committed",
      "weight": 6,
      "properties": {
        "language": [
          "javascript",
          "python",
          "go",
          "rust",
          "java"
        ],
        "linesChanged": {
          "$range": [
            97,
            393
          ]
        }
      }
    },
    {
      "event": "deployment run",
      "weight": 3,
      "properties": {
        "environment": [
          "dev",
          "staging",
          "production"
        ],
        "status": [
          "success",
          "failure"
        ],
        "durationSec": {
          "$range": [
            65,
            243
          ]
        }
      }
    },
    {
      "event": "login",
      "weight": 5,
      "isFirstEvent": true,
      "properties": {
        "method": [
          "password",
          "sso",
          "oauth"
        ]
      }
    }
  ],
  "userProps": {
    "role": [
      "engineer",
      "designer",
      "pm",
      "manager",
      "exec"
    ]
  },
  "groupKeys": [
    {
      "key": "company_id",
      "count": 50,
      "affectsEvents": [
        "feature used",
        "subscription change",
        "support ticket"
      ]
    },
    {
      "key": "team_id",
      "count": 200,
      "affectsEvents": [
        "feature used",
        "task completed",
        "meeting scheduled"
      ]
    },
    {
      "key": "project_id",
      "count": 500,
      "affectsEvents": [
        "task completed",
        "code committed",
        "deployment run"
      ]
    }
  ],
  "groupProps": {
    "company_id": {
      "name": {
        "$type": "string"
      },
      "industry": [
        "technology",
        "finance",
        "healthcare",
        "retail",
        "education",
        "manufacturing"
      ],
      "plan": [
        "free",
        "starter",
        "business",
        "enterprise"
      ],
      "employee_count": {
        "$range": [
          964,
          3784
        ]
      }
    },
    "team_id": {
      "name": {
        "$type": "string"
      },
      "department": [
        "engineering",
        "design",
        "product",
        "marketing",
        "sales",
        "support"
      ],
      "size": {
        "$range": [
          3,
          20
        ]
      }
    },
    "project_id": {
      "name": {
        "$type": "string"
      },
      "status": [
        "active",
        "paused",
        "completed",
        "archived"
      ],
      "priority": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    }
  }
}
