# ── OS / editor noise ──────────────────────────────────────────────
.DS_Store
**/.DS_Store
vscode-profile-*

# ── Secrets ────────────────────────────────────────────────────────
.env
env.yml

# ── Dependencies ───────────────────────────────────────────────────
node_modules

# ── Generated data + logs ──────────────────────────────────────────
data/*
!data/.gitkeep
log.json
*.log
*.bak

# ── Test coverage + temp scratch ───────────────────────────────────
tests/coverage/*
!tests/coverage/.gitkeep
tmp/*
!tmp/.gitkeep
.tmp/
duckdb_temp_*
*scratch*

# ── User / customer dungeons (not shipped in package) ──────────────
customers
dungeons/customers/*
!dungeons/customers/.gitkeep
dungeons/user/*
!dungeons/user/.gitkeep
dungeons/capstone/*
dungeons/*ai-dungeon*

# ── Internal working artifacts ─────────────────────────────────────
# Plans + research are ephemeral working dirs (designs, sweep outputs,
# implementor status files). Final docs land in docs/guides/ and CHANGELOG.md.
plans/*
!plans/.gitkeep
research/*
!research/.gitkeep
scripts/experiments/
scripts/kodiak/validate.sql
dungeons/user/kodiak/validate.sql
dungeons/user/kodiak/chunk-plan.json
chunk-plan.json
logs/kodiak/

# ── Excluded examples ──────────────────────────────────────────────
examples/*

# ── Catch-all ignore prefix ────────────────────────────────────────
ignore*
PHASE1-IMPROVEMENTS.md
