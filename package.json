{
	"name": "@ak--47/dungeon-master",
	"version": "1.2.1",
	"description": "generate fancy datasets",
	"type": "module",
	"main": "index.js",
	"types": "types.d.ts",
	"exports": {
		".": {
			"import": "./index.js",
			"types": "./types.d.ts"
		},
		"./utils": "./lib/utils/utils.js",
		"./text": "./lib/generators/text.js"
	},
	"files": [
		"index.js",
		"types.d.ts",
		"lib/",
		"dungeons/",
		"!dungeons/customers/",
		"scripts/",
		"package.json",
		"README.md"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"post": "npm publish",
		"test": "NODE_ENV=test vitest run",
		"test:coverage": "NODE_ENV=test vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"dev": "nodemon scratch.mjs --ignore ./data/*",
		"prune": "rm -f ./data/* && rm -f ./tmp/* && rm -f vscode-profile-*",
		"dungeon:run": "node ./scripts/run-dungeon.mjs",
		"dungeon:to-json": "node ./scripts/dungeon-to-json.mjs",
		"dungeon:from-json": "node ./scripts/json-to-dungeon.mjs",
		"dungeon:schema": "node ./scripts/extract-dungeon-schema.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ak--47/dungeon-master.git"
	},
	"keywords": [
		"mixpanel",
		"analytics",
		"tracking",
		"datamart",
		"scd 2",
		"dummy data",
		"fake data",
		"data generation"
	],
	"author": "ak@mixpanel.com",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/ak--47/dungeon-master/issues"
	},
	"homepage": "https://github.com/ak--47/dungeon-master#readme",
	"dependencies": {
		"@google-cloud/storage": "^7.14.0",
		"ak-tools": "^1.1.12",
		"chance": "^1.1.11",
		"dayjs": "^1.11.11",
		"dotenv": "^16.4.5",
		"hyparquet-writer": "^0.6.1",
		"mixpanel": "^0.18.0",
		"mixpanel-import": "^3.2.8",
		"p-limit": "^3.1.0",
		"pino": "^9.0.0",
		"pino-pretty": "^11.0.0",
		"seedrandom": "^3.0.5",
		"sentiment": "^5.0.2",
		"tracery-grammar": "^2.8.4"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^2.1.9",
		"@vitest/ui": "^2.1.9",
		"nodemon": "^3.1.3",
		"typescript": "^5.6.0",
		"vitest": "^2.1.9"
	},
	"nodemonConfig": {
		"ignore": [
			"data/",
			"tmp/"
		]
	}
}
